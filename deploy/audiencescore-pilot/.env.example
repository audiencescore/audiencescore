# AudienceScore pilot deployment, pre-cryptographic-audit.
# Copy to .env on the VPS only. Never commit real secrets, keys, customer data,
# or configured webhook secrets.

AUDIENCESCORE_PUBLIC_BASE_URL=https://api.audiencescore.org
AUDIENCESCORE_HOST_DATA_DIR=/opt/audiencescore-pilot/data
AUDIENCESCORE_DATA_DIR=/data
AUDIENCESCORE_DB_PATH=/data/pilot.sqlite
AUDIENCESCORE_KEYS_DIR=/data/keys
AUDIENCESCORE_OUTBOX_DIR=/data/outbox
AUDIENCESCORE_BACKUP_DIR=/data/backups

# file writes .eml messages to AUDIENCESCORE_OUTBOX_DIR. smtp sends them.
AUDIENCESCORE_EMAIL_MODE=file
AUDIENCESCORE_EMAIL_FROM=pilot@audiencescore.org
# AUDIENCESCORE_SMTP_HOST=
# AUDIENCESCORE_SMTP_PORT=587
# AUDIENCESCORE_SMTP_SECURE=false
# AUDIENCESCORE_SMTP_STARTTLS=true
# AUDIENCESCORE_SMTP_USER=
# AUDIENCESCORE_SMTP_PASSWORD=

# JSON object mapping issuer_id -> Stripe webhook secret.
# Example only:
# AUDIENCESCORE_STRIPE_WEBHOOK_SECRETS_JSON={"field-elevate-pilot":"REPLACE_WITH_STRIPE_WEBHOOK_SECRET_ON_VPS"}
AUDIENCESCORE_STRIPE_WEBHOOK_SECRETS_JSON={}
